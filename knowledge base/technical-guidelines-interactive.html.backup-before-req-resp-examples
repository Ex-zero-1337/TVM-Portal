  <style>
    :root{color-scheme:dark;--bg:#0d0f12;--panel:#171b21;--panel2:#202631;--line:#303846;--text:#edf2f7;--muted:#a9b4c2;--accent:#4ea1ff;--crit:#ff5b6b;--high:#ff9f43;--med:#f3cf4c;--low:#5cc8ff;--info:#9aa4b2}
    *{box-sizing:border-box} body{margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;background:var(--bg);color:var(--text);line-height:1.45}
    header{position:sticky;top:0;z-index:2;background:linear-gradient(180deg,#151a20,#101318);border-bottom:1px solid var(--line);padding:18px 24px}
    h1{margin:0 0 6px;font-size:24px} p{color:var(--muted)} main{display:grid;grid-template-columns:300px 1fr;gap:20px;padding:20px}
    aside{position:sticky;top:90px;align-self:start;background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:14px}
