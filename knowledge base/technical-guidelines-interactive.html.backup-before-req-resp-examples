  <script>
    const q = document.querySelector('#q'), domain = document.querySelector('#domain'), severity = document.querySelector('#severity')
    const items = [...document.querySelectorAll('.finding')]
    function apply(){
      const text = q.value.trim().toLowerCase(), d = domain.value, s = severity.value
      for (const item of items) {
        const ok = (!text || item.dataset.text.includes(text)) && (!d || item.dataset.domain === d) && (!s || item.dataset.severity === s)
        item.classList.toggle('hidden', !ok)
      }
    }
    q.addEventListener('input', apply); domain.addEventListener('change', apply); severity.addEventListener('change', apply)
    document.querySelector('#expand').onclick = () => items.forEach(i => i.classList.add('open'))
    document.querySelector('#collapse').onclick = () => items.forEach(i => i.classList.remove('open'))
    items.forEach(i => i.querySelector('.finding-head').addEventListener('click', () => i.classList.toggle('open')))
  </script>
