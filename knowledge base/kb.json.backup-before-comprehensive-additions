[
  {"id":"kb-1","title":"SQL Injection","severity":"Critical","description":"User input is concatenated into SQL statements.","risk":"Full database compromise, data exfiltration.","recommendation":"Use parameterized queries / ORM; least-privilege DB accounts.","cve":"","cwe":"CWE-89","owasp":"A03:2021 Injection","createdAt":"2026-01-05T10:00:00Z","updatedAt":"2026-01-05T10:00:00Z"},
  {"id":"kb-2","title":"Missing Security Headers","severity":"Low","description":"Responses lack important browser security headers such as Content-Security-Policy, Strict-Transport-Security, X-Frame-Options, X-Content-Type-Options, or Referrer-Policy.","risk":"Increases exposure to clickjacking, MIME sniffing, downgrade attacks, and client-side injection impact.","recommendation":"Implement a hardened baseline of HTTP security headers appropriate to the application and test for regressions in CI/CD.","cve":"","cwe":"CWE-693","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-01-05T10:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-3","title":"Cross-Site Scripting (Reflected)","severity":"High","description":"User-controlled input is reflected in the response without sufficient output encoding or sanitization.","risk":"An attacker may execute JavaScript in a victim browser, steal session data, perform actions as the user, or alter page content.","recommendation":"Apply context-aware output encoding, validate input, sanitize trusted HTML with a proven library, and deploy a restrictive Content-Security-Policy.","cve":"","cwe":"CWE-79","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-4","title":"Cross-Site Scripting (Stored)","severity":"Critical","description":"Untrusted input is stored by the application and later rendered to other users without sufficient output encoding or sanitization.","risk":"Persistent script execution can compromise multiple users, including privileged users, and may lead to account takeover or unauthorized administrative actions.","recommendation":"Perform context-aware output encoding on render, sanitize rich text on input and output, restrict dangerous HTML, and invalidate affected stored content.","cve":"","cwe":"CWE-79","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-5","title":"Broken Access Control / IDOR","severity":"High","description":"The application exposes object identifiers that can be modified to access another user's records or resources.","risk":"Unauthorized disclosure, modification, or deletion of sensitive business data belonging to other users or tenants.","recommendation":"Enforce server-side authorization checks for every object access, use indirect identifiers where appropriate, and add automated authorization tests.","cve":"","cwe":"CWE-639","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-6","title":"Privilege Escalation","severity":"Critical","description":"A lower-privileged user can access administrative functions or perform actions beyond their assigned role.","risk":"Complete compromise of application administration, unauthorized data changes, or bypass of operational controls.","recommendation":"Implement centralized role and permission enforcement on the server, deny by default, and test horizontal and vertical authorization boundaries.","cve":"","cwe":"CWE-269","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-7","title":"Authentication Bypass","severity":"Critical","description":"Authentication controls can be bypassed due to flawed logic, missing verification, or trust in client-controlled state.","risk":"Attackers may gain unauthorized access to accounts or protected application functionality without valid credentials.","recommendation":"Enforce authentication on the server for every protected route/API, avoid trusting client-side flags, and add negative authentication tests.","cve":"","cwe":"CWE-287","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-8","title":"Weak Password Policy","severity":"Medium","description":"The application allows weak, common, short, or easily guessable passwords.","risk":"Accounts are more susceptible to credential guessing, password spraying, and brute-force attacks.","recommendation":"Require strong password length and complexity or passphrase controls, block common passwords, and support MFA for sensitive roles.","cve":"","cwe":"CWE-521","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-9","title":"Missing Account Lockout / Brute Force Protection","severity":"Medium","description":"Login or sensitive authentication endpoints do not sufficiently throttle repeated failed attempts.","risk":"Attackers can conduct password guessing or credential stuffing attacks at scale.","recommendation":"Implement rate limiting, progressive delays, account lockout or risk-based challenges, monitoring, and alerting for suspicious login attempts.","cve":"","cwe":"CWE-307","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-10","title":"Insecure Session Cookie Attributes","severity":"Medium","description":"Session cookies are missing security attributes such as Secure, HttpOnly, or SameSite.","risk":"Session tokens may be exposed through client-side script, transmitted over insecure channels, or abused in cross-site request scenarios.","recommendation":"Set session cookies with Secure, HttpOnly, and an appropriate SameSite value; ensure cookies are only issued over HTTPS.","cve":"","cwe":"CWE-614","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-11","title":"Session Fixation","severity":"High","description":"The application does not rotate the session identifier after successful authentication or privilege change.","risk":"An attacker who obtains or sets a victim session identifier may hijack the authenticated session.","recommendation":"Regenerate session identifiers after login, logout, password changes, MFA enrollment, and privilege changes; invalidate old session IDs.","cve":"","cwe":"CWE-384","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-12","title":"Cross-Site Request Forgery (CSRF)","severity":"Medium","description":"State-changing requests can be submitted without a valid anti-CSRF token or equivalent protection.","risk":"An attacker may trick authenticated users into performing unintended actions such as changing account settings or submitting transactions.","recommendation":"Use per-request or per-session CSRF tokens, SameSite cookies, origin/referrer validation, and require re-authentication for high-risk actions.","cve":"","cwe":"CWE-352","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-13","title":"Unrestricted File Upload","severity":"High","description":"The application accepts file uploads without sufficient validation of file type, extension, content, size, or storage location.","risk":"Attackers may upload executable files, malware, web shells, or oversized files that lead to code execution, data compromise, or denial of service.","recommendation":"Allowlist file types, verify content signatures, rename files, store uploads outside the web root, scan files, enforce size limits, and disable execution in upload directories.","cve":"","cwe":"CWE-434","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-14","title":"Path Traversal","severity":"High","description":"User-controlled path input can access files or directories outside the intended application directory.","risk":"Sensitive files, configuration secrets, source code, or system files may be read or modified.","recommendation":"Normalize and validate paths using safe path APIs, enforce an allowlisted base directory, reject traversal sequences, and avoid direct use of user input in file paths.","cve":"","cwe":"CWE-22","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-15","title":"Server-Side Request Forgery (SSRF)","severity":"High","description":"The application fetches user-supplied URLs or network locations without restricting destination hosts or protocols.","risk":"Attackers may access internal services, cloud metadata endpoints, or perform network scanning through the server.","recommendation":"Allowlist trusted destinations, block private/link-local/internal IP ranges, restrict protocols, disable redirects where possible, and isolate outbound fetch services.","cve":"","cwe":"CWE-918","owasp":"A10:2021 Server-Side Request Forgery","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-16","title":"XML External Entity (XXE)","severity":"High","description":"XML input is parsed with external entity processing enabled.","risk":"Attackers may read local files, trigger SSRF, or cause denial of service through malicious XML payloads.","recommendation":"Disable external entity resolution and DTD processing, use hardened XML parsers, and prefer safer data formats where possible.","cve":"","cwe":"CWE-611","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-17","title":"Command Injection","severity":"Critical","description":"User-controlled input is passed to operating system commands without safe handling.","risk":"Attackers may execute arbitrary commands on the server, leading to full host compromise.","recommendation":"Avoid shell execution with user input, use safe APIs, pass arguments as structured arrays, validate allowlisted values, and run processes with least privilege.","cve":"","cwe":"CWE-78","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-18","title":"LDAP Injection","severity":"High","description":"User input is inserted into LDAP queries without proper escaping or parameterization.","risk":"Attackers may bypass authentication, enumerate directory data, or modify LDAP query logic.","recommendation":"Use safe LDAP query builders, escape special characters, validate input, and enforce least-privilege LDAP bind accounts.","cve":"","cwe":"CWE-90","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-19","title":"Insecure Direct API Endpoint Exposure","severity":"High","description":"API endpoints expose sensitive operations or data without sufficient authentication, authorization, or server-side validation.","risk":"Attackers may bypass UI restrictions and directly call APIs to access or manipulate data.","recommendation":"Apply consistent authentication and authorization to every API, validate all server-side inputs, and add API abuse monitoring.","cve":"","cwe":"CWE-306","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-20","title":"Sensitive Data Exposure in Response","severity":"Medium","description":"Application responses include sensitive data such as tokens, credentials, internal identifiers, PII, stack traces, or excessive account details.","risk":"Exposed data may support account takeover, privacy violations, fraud, or further attacks against internal systems.","recommendation":"Return only required fields, mask sensitive values, remove debug details, and review API response schemas for least disclosure.","cve":"","cwe":"CWE-200","owasp":"A02:2021 Cryptographic Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-21","title":"Sensitive Information in Client-Side Code","severity":"Medium","description":"Secrets, API keys, internal URLs, credentials, or sensitive business logic are exposed in JavaScript, source maps, or bundled client files.","risk":"Attackers may extract secrets, discover hidden endpoints, or better understand application internals for targeted attacks.","recommendation":"Remove secrets from client code, rotate exposed keys, restrict API keys by origin/scope, and disable source maps in production unless access-controlled.","cve":"","cwe":"CWE-798","owasp":"A02:2021 Cryptographic Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-22","title":"Verbose Error Messages / Stack Trace Disclosure","severity":"Low","description":"The application exposes detailed error messages, stack traces, framework versions, or internal paths to users.","risk":"Attackers can use the information to fingerprint technologies, discover internal paths, and craft targeted exploits.","recommendation":"Return generic error messages to users, log detailed errors server-side only, and disable debug mode in production.","cve":"","cwe":"CWE-209","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-26","title":"Insecure CORS Configuration","severity":"Medium","description":"The application allows overly broad cross-origin requests, such as wildcard origins with credentials or reflection of arbitrary origins.","risk":"Malicious websites may read sensitive API responses from authenticated users if browser credentials are included.","recommendation":"Allowlist trusted origins only, avoid wildcard origins for authenticated APIs, do not reflect arbitrary origins, and review credentialed CORS usage.","cve":"","cwe":"CWE-942","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-27","title":"Clickjacking","severity":"Low","description":"The application can be embedded in a frame by untrusted websites due to missing or weak frame protection.","risk":"Attackers may trick users into performing unintended clicks or actions through UI redressing attacks.","recommendation":"Set Content-Security-Policy frame-ancestors and/or X-Frame-Options to restrict framing to trusted origins.","cve":"","cwe":"CWE-1021","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-28","title":"Open Redirect","severity":"Low","description":"The application redirects users to a URL controlled by user input without validation.","risk":"Attackers may craft trusted-looking links that redirect victims to phishing sites or malicious downloads.","recommendation":"Use relative redirects or allowlist trusted redirect destinations; avoid accepting arbitrary full URLs from user input.","cve":"","cwe":"CWE-601","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-29","title":"Business Logic Bypass","severity":"High","description":"Application workflow or server-side validation can be bypassed to perform actions out of sequence or outside business rules.","risk":"Attackers may manipulate transactions, approvals, limits, discounts, or operational controls without exploiting a technical injection flaw.","recommendation":"Enforce business rules server-side, validate state transitions, use idempotency and transaction controls, and test negative workflow paths.","cve":"","cwe":"CWE-840","owasp":"A04:2021 Insecure Design","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-30","title":"Insufficient Logging and Monitoring","severity":"Low","description":"Security-relevant events such as login failures, privilege changes, data exports, or administrative actions are not logged or monitored adequately.","risk":"Security incidents may go undetected, investigation may be delayed, and audit requirements may not be met.","recommendation":"Log security events with sufficient context, protect logs from tampering, alert on suspicious activity, and review logs regularly.","cve":"","cwe":"CWE-778","owasp":"A09:2021 Security Logging and Monitoring Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-31","title":"Mobile Application Allows Cleartext Traffic","severity":"High","description":"The mobile application permits HTTP or other cleartext network communication through platform configuration or runtime behavior.","risk":"Network attackers may intercept or modify sensitive traffic, credentials, tokens, or API responses.","recommendation":"Disable cleartext traffic in Android Network Security Configuration and iOS App Transport Security exceptions unless strictly required; enforce HTTPS with modern TLS for all endpoints.","cve":"","cwe":"CWE-319","owasp":"M3:2024 Insecure Communication","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-32","title":"Mobile Insecure Data Storage","severity":"High","description":"Sensitive information such as access tokens, credentials, PII, account data, or transaction details is stored insecurely on the device.","risk":"Attackers with device access, backup access, malware, or a compromised device may extract sensitive data.","recommendation":"Store secrets only in Android Keystore or iOS Keychain with appropriate access controls, avoid storing sensitive data unnecessarily, encrypt local databases, and clear temporary sensitive data.","cve":"","cwe":"CWE-922","owasp":"M9:2024 Insecure Data Storage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-33","title":"Mobile Hardcoded Secrets","severity":"High","description":"The mobile application package contains hardcoded API keys, encryption keys, credentials, tokens, private URLs, or other sensitive secrets.","risk":"Attackers may reverse engineer the application and abuse exposed secrets to access backend services or bypass controls.","recommendation":"Remove secrets from the client, rotate exposed values, move sensitive operations to the server, and restrict any unavoidable client keys by scope, platform, certificate, and backend authorization.","cve":"","cwe":"CWE-798","owasp":"M8:2024 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-34","title":"Mobile Weak Certificate Pinning or Missing Pinning","severity":"Medium","description":"The mobile application does not implement certificate pinning for sensitive connections, or the implemented pinning can be bypassed due to weak design.","risk":"Users on hostile networks or compromised devices may be exposed to interception if a rogue or user-installed certificate is trusted.","recommendation":"Implement certificate or public-key pinning for high-risk APIs, use platform-supported TLS validation, fail closed on pinning errors, and maintain a secure pin rotation strategy.","cve":"","cwe":"CWE-295","owasp":"M3:2024 Insecure Communication","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-35","title":"Mobile Improper TLS Certificate Validation","severity":"Critical","description":"The mobile application accepts invalid, self-signed, expired, mismatched, or untrusted TLS certificates.","risk":"Attackers may perform man-in-the-middle attacks and intercept or tamper with sensitive application traffic.","recommendation":"Use the platform default trust manager, reject invalid certificates, remove custom permissive trust logic, and test certificate validation on both trusted and untrusted networks.","cve":"","cwe":"CWE-295","owasp":"M3:2024 Insecure Communication","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-36","title":"Mobile Root or Jailbreak Detection Missing","severity":"Medium","description":"The application does not detect or respond to rooted Android devices or jailbroken iOS devices for sensitive workflows.","risk":"A compromised device can make runtime tampering, credential extraction, hooking, and local data access easier.","recommendation":"Add layered root/jailbreak detection, integrity checks, risk-based restrictions for sensitive actions, and server-side fraud monitoring; do not rely on client checks as the only control.","cve":"","cwe":"CWE-693","owasp":"M8:2024 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-37","title":"Mobile Runtime Tampering Protection Missing","severity":"Medium","description":"The application lacks defenses against dynamic instrumentation, hooking frameworks, debugging, or runtime modification.","risk":"Attackers may bypass client-side controls, inspect secrets, alter transaction flows, or manipulate application behavior.","recommendation":"Implement layered anti-debugging, anti-hooking, integrity validation, obfuscation, and server-side validation for critical decisions; monitor suspicious device and session signals.","cve":"","cwe":"CWE-693","owasp":"M7:2024 Insufficient Binary Protections","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-38","title":"Mobile Debuggable Build Enabled","severity":"High","description":"The production Android application is built with the debuggable flag enabled or exposes debugging capabilities.","risk":"Attackers may attach debuggers, inspect runtime state, extract data, or bypass client-side protections more easily.","recommendation":"Disable debuggable mode for release builds, enforce release signing and build checks in CI/CD, and verify production artifacts before distribution.","cve":"","cwe":"CWE-489","owasp":"M8:2024 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-39","title":"Mobile Backup Enabled for Sensitive App Data","severity":"Medium","description":"The mobile application allows sensitive local data to be included in device backups or cloud backups.","risk":"Sensitive data may be restored to unauthorized devices or extracted from backup files.","recommendation":"Disable Android backup for sensitive apps or exclude sensitive files with backup rules; configure iOS data protection and avoid storing sensitive information in backup-accessible locations.","cve":"","cwe":"CWE-922","owasp":"M9:2024 Insecure Data Storage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-40","title":"Mobile Sensitive Data in Logs","severity":"Medium","description":"The mobile application writes sensitive values such as tokens, passwords, OTPs, PII, or API responses to system or application logs.","risk":"Logs may be accessed by developers, support tooling, malware, or attackers with device access, exposing sensitive data.","recommendation":"Remove sensitive logging, mask values before logging, disable verbose logs in release builds, and review third-party SDK logging behavior.","cve":"","cwe":"CWE-532","owasp":"M9:2024 Insecure Data Storage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-41","title":"Mobile Sensitive Data in Clipboard","severity":"Low","description":"The application places sensitive information such as OTPs, account numbers, tokens, or personal data into the system clipboard.","risk":"Other applications or system features may read clipboard content, causing unintended disclosure.","recommendation":"Avoid copying sensitive values to the clipboard, provide masked display options, clear clipboard data where supported, and warn users when sensitive copying is necessary.","cve":"","cwe":"CWE-200","owasp":"M9:2024 Insecure Data Storage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-42","title":"Mobile Insecure Deep Link Handling","severity":"High","description":"The mobile application accepts deep links, app links, or universal links without proper validation of parameters, origins, or target actions.","risk":"Attackers may trigger unauthorized actions, steal tokens, perform phishing, or bypass intended navigation and authentication flows.","recommendation":"Validate all deep link parameters server-side and client-side, require authentication for sensitive actions, restrict accepted hosts/schemes, and avoid placing secrets in URLs.","cve":"","cwe":"CWE-939","owasp":"M4:2024 Insufficient Input/Output Validation","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-43","title":"Mobile Exported Android Component Exposure","severity":"High","description":"Android activities, services, broadcast receivers, or content providers are exported without sufficient permission checks or input validation.","risk":"Other applications may invoke internal functionality, access data, or manipulate application behavior.","recommendation":"Set exported=false for internal components, protect required exported components with signature-level permissions, validate intents, and avoid exposing sensitive content providers.","cve":"","cwe":"CWE-926","owasp":"M8:2024 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-44","title":"Mobile Insecure Inter-Process Communication","severity":"High","description":"The application exchanges sensitive data through intents, broadcasts, URL schemes, pasteboard, or IPC channels without sufficient protection.","risk":"Malicious applications may intercept, spoof, or tamper with messages and sensitive data.","recommendation":"Use explicit intents, signature permissions, local-only communication where possible, encrypted payloads for sensitive data, and strict validation of IPC inputs.","cve":"","cwe":"CWE-927","owasp":"M1:2024 Improper Credential Usage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-45","title":"Mobile WebView JavaScript Interface Exposure","severity":"High","description":"A WebView exposes JavaScript bridges or unsafe settings that allow untrusted web content to interact with native application functions.","risk":"Attackers may execute native actions, access local data, or escalate impact from web content injection.","recommendation":"Disable JavaScript when not required, restrict loaded origins, remove unsafe JavaScript interfaces, validate bridge inputs, and avoid loading untrusted content in privileged WebViews.","cve":"","cwe":"CWE-749","owasp":"M4:2024 Insufficient Input/Output Validation","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-46","title":"Mobile Weak Cryptography","severity":"High","description":"The application uses weak cryptographic algorithms, static keys, predictable IVs, insecure random generation, or custom cryptographic routines.","risk":"Encrypted data may be decrypted, forged, or tampered with by attackers.","recommendation":"Use modern vetted cryptographic libraries, AES-GCM or platform-approved algorithms, secure random generation, proper key management, and avoid custom crypto.","cve":"","cwe":"CWE-327","owasp":"M10:2024 Insufficient Cryptography","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-47","title":"Mobile Biometric Authentication Bypass","severity":"High","description":"The application relies on local biometric prompts without binding successful authentication to secure hardware or server-side session controls.","risk":"Attackers may bypass biometric checks through hooking, tampering, or insecure local state changes.","recommendation":"Use platform biometric APIs with cryptographic objects where appropriate, require server-side authorization for sensitive actions, and avoid using local flags as proof of authentication.","cve":"","cwe":"CWE-287","owasp":"M1:2024 Improper Credential Usage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-48","title":"Mobile Screen Capture Protection Missing","severity":"Low","description":"Sensitive screens can be captured through screenshots, screen recording, recent-app previews, or overlays.","risk":"Sensitive information may be exposed through device galleries, app switcher thumbnails, support recordings, or malicious overlay techniques.","recommendation":"Apply Android FLAG_SECURE and iOS screen privacy controls on sensitive views, mask app switcher previews, and reduce sensitive on-screen exposure.","cve":"","cwe":"CWE-200","owasp":"M9:2024 Insecure Data Storage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-49","title":"Mobile Insecure Local Database Storage","severity":"High","description":"The application stores sensitive data in local SQLite, Realm, Core Data, or flat files without encryption or adequate access controls.","risk":"Attackers with filesystem or backup access may extract sensitive business data, PII, or session information.","recommendation":"Encrypt local databases using vetted libraries, store keys in Android Keystore or iOS Keychain, minimize local retention, and clear stale sensitive data.","cve":"","cwe":"CWE-922","owasp":"M9:2024 Insecure Data Storage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-50","title":"Mobile Insecure Token Refresh Flow","severity":"High","description":"Refresh tokens or session renewal logic are weakly protected, long-lived without rotation, or accepted without device/session binding.","risk":"Stolen refresh tokens may allow persistent account access even after access tokens expire.","recommendation":"Use refresh token rotation, revoke reused tokens, bind sessions to device and risk signals where appropriate, store tokens securely, and require re-authentication for high-risk events.","cve":"","cwe":"CWE-613","owasp":"M1:2024 Improper Credential Usage","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-51","title":"API Broken Object Level Authorization","severity":"High","description":"API endpoints allow users to access objects by changing identifiers without proper object-level authorization checks.","risk":"Attackers may access or modify records belonging to other users, departments, or tenants.","recommendation":"Enforce object-level authorization on every API request, avoid relying on client-side filtering, and add automated negative tests for cross-user and cross-tenant access.","cve":"","cwe":"CWE-639","owasp":"API1:2023 Broken Object Level Authorization","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-52","title":"API Mass Assignment","severity":"High","description":"The API automatically binds client-supplied fields to internal objects without restricting fields that users are allowed to set.","risk":"Attackers may modify protected properties such as roles, account status, ownership, limits, or approval flags.","recommendation":"Use explicit allowlists for writable fields, separate input DTOs from internal models, and reject unexpected properties in API requests.","cve":"","cwe":"CWE-915","owasp":"API3:2023 Broken Object Property Level Authorization","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-53","title":"API Excessive Data Exposure","severity":"Medium","description":"API responses return more data than required by the client, including hidden fields, internal identifiers, or sensitive user attributes.","risk":"Attackers may obtain information useful for privacy violations, fraud, account takeover, or further exploitation.","recommendation":"Define response schemas per use case, filter sensitive fields server-side, avoid relying on the client to hide data, and review API contracts regularly.","cve":"","cwe":"CWE-200","owasp":"API3:2023 Broken Object Property Level Authorization","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-54","title":"API Lack of Resource and Rate Limiting","severity":"Medium","description":"The API does not sufficiently limit request rate, payload size, pagination size, expensive queries, or repeated sensitive operations.","risk":"Attackers may perform brute force attacks, scraping, enumeration, or denial of service.","recommendation":"Apply rate limits, quota controls, pagination caps, request size limits, account-based throttling, and monitoring for abnormal API usage.","cve":"","cwe":"CWE-770","owasp":"API4:2023 Unrestricted Resource Consumption","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-55","title":"Insecure Mobile API Error Handling","severity":"Low","description":"Mobile backend APIs return detailed errors, stack traces, internal codes, or validation details that reveal implementation information.","risk":"Attackers may use exposed information to fingerprint backend technologies, enumerate valid records, or refine attacks.","recommendation":"Return generic client-safe errors, log details server-side, normalize authentication and authorization failures, and avoid exposing internal exception details.","cve":"","cwe":"CWE-209","owasp":"API8:2023 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-56","title":"HTML Injection","severity":"Medium","description":"User-controlled input is rendered as HTML without sufficient encoding, allowing attackers to inject arbitrary markup.","risk":"Attackers may alter page content, perform phishing, mislead users, or create a path toward script execution depending on browser and context.","recommendation":"Use context-aware output encoding, sanitize allowed rich text with a proven library, and avoid rendering untrusted input as raw HTML.","cve":"","cwe":"CWE-79","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-57","title":"DOM-Based Cross-Site Scripting","severity":"High","description":"Client-side JavaScript processes untrusted data from URLs, storage, messages, or APIs and writes it into dangerous DOM sinks.","risk":"Attackers may execute JavaScript in the victim browser, steal tokens, manipulate UI content, or perform actions as the user.","recommendation":"Avoid dangerous DOM sinks, use safe DOM APIs, validate and encode untrusted data, sanitize HTML with a proven library, and apply a restrictive Content-Security-Policy.","cve":"","cwe":"CWE-79","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-58","title":"Content Security Policy Misconfiguration","severity":"Medium","description":"The Content-Security-Policy is missing, overly permissive, uses unsafe directives, or does not meaningfully reduce script injection impact.","risk":"Successful injection vulnerabilities may have greater impact, and attackers may load malicious scripts, frames, or resources from untrusted locations.","recommendation":"Define a restrictive CSP with nonce or hash based script execution, avoid unsafe-inline and unsafe-eval, restrict frame/object sources, and test policy violations before enforcement.","cve":"","cwe":"CWE-693","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-59","title":"JWT Misconfiguration","severity":"High","description":"JSON Web Tokens are accepted with weak validation, insecure algorithms, missing expiration checks, or improper signature verification.","risk":"Attackers may forge, replay, or tamper with tokens to impersonate users or escalate privileges.","recommendation":"Enforce strong signing algorithms, verify signatures and claims server-side, reject none or unexpected algorithms, use short token lifetimes, and rotate keys securely.","cve":"","cwe":"CWE-347","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-60","title":"Password Reset Poisoning","severity":"High","description":"The password reset flow trusts user-controlled host, origin, or callback values when generating reset links.","risk":"Attackers may cause reset tokens to be sent in links pointing to attacker-controlled domains, enabling account takeover.","recommendation":"Generate reset URLs from a trusted server-side base URL, validate host headers, avoid user-controlled callback domains, and expire reset tokens quickly after use.","cve":"","cwe":"CWE-640","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-61","title":"User Enumeration","severity":"Low","description":"Authentication, registration, password reset, or lookup flows reveal whether an account, email address, or username exists.","risk":"Attackers may build valid user lists for phishing, credential stuffing, social engineering, or targeted attacks.","recommendation":"Use consistent responses and timing for valid and invalid accounts, rate limit enumeration-prone endpoints, and monitor suspicious lookup patterns.","cve":"","cwe":"CWE-203","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-62","title":"Missing Multi-Factor Authentication for Privileged Users","severity":"High","description":"Administrative or high-risk accounts can authenticate without multi-factor authentication.","risk":"Compromised passwords may provide direct access to sensitive data, privileged workflows, or administrative controls.","recommendation":"Require phishing-resistant MFA where possible for privileged users, enforce step-up authentication for sensitive actions, and monitor privileged login anomalies.","cve":"","cwe":"CWE-308","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-63","title":"Improper Logout Session Invalidation","severity":"Medium","description":"Sessions or tokens remain valid after logout, password change, or account deactivation.","risk":"Stolen or previously issued tokens may continue to grant access after the user expects the session to be terminated.","recommendation":"Invalidate server-side sessions on logout and security events, revoke refresh tokens, clear client tokens, and verify session termination across devices where required.","cve":"","cwe":"CWE-613","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-64","title":"Insecure Direct File Download","severity":"High","description":"The application allows users to download files by modifying file identifiers, paths, or URLs without proper authorization checks.","risk":"Attackers may retrieve documents, reports, attachments, or personal files belonging to other users or business units.","recommendation":"Enforce authorization on every file download, use indirect file references, avoid exposing storage paths, and log suspicious download attempts.","cve":"","cwe":"CWE-639","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-65","title":"Template Injection","severity":"Critical","description":"User-controlled input is evaluated by a server-side or client-side template engine without safe handling.","risk":"Attackers may execute code, access sensitive objects, read files, or compromise the server depending on the template engine.","recommendation":"Avoid evaluating user input as templates, use safe rendering modes, sandbox template execution, validate input, and keep template engines updated.","cve":"","cwe":"CWE-94","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-66","title":"Insecure Deserialization","severity":"Critical","description":"The application deserializes untrusted data without integrity protection, type restrictions, or safe parsing controls.","risk":"Attackers may trigger remote code execution, authentication bypass, data tampering, or denial of service.","recommendation":"Avoid deserializing untrusted data, use safe data formats, enforce type allowlists, sign serialized objects, and isolate risky parsing logic.","cve":"","cwe":"CWE-502","owasp":"A08:2021 Software and Data Integrity Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-67","title":"HTTP Request Smuggling","severity":"High","description":"Front-end and back-end servers parse ambiguous HTTP requests differently due to inconsistent handling of headers such as Content-Length and Transfer-Encoding.","risk":"Attackers may bypass security controls, poison responses, hijack requests, or access other users' data through desynchronized connections.","recommendation":"Normalize HTTP parsing across proxy and origin layers, reject ambiguous requests, keep web components updated, and test reverse proxy chains for desynchronization issues.","cve":"","cwe":"CWE-444","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-68","title":"Cache Poisoning","severity":"High","description":"The application or intermediary cache stores responses influenced by untrusted headers, parameters, or host values.","risk":"Attackers may serve malicious or sensitive cached content to other users, causing XSS, phishing, or data exposure.","recommendation":"Define strict cache keys, avoid caching user-specific responses publicly, validate host and forwarding headers, and set appropriate Cache-Control headers.","cve":"","cwe":"CWE-444","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-69","title":"Host Header Injection","severity":"Medium","description":"The application trusts the Host or forwarded host headers when generating links, redirects, password reset URLs, or absolute references.","risk":"Attackers may poison links, perform phishing, bypass origin checks, or exploit cache and password reset flows.","recommendation":"Validate allowed hostnames at the edge and application layer, generate absolute URLs from trusted configuration, and reject unexpected forwarded host values.","cve":"","cwe":"CWE-20","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-70","title":"CSV Formula Injection","severity":"Medium","description":"Exported CSV or spreadsheet files include user-controlled values that can be interpreted as formulas by spreadsheet applications.","risk":"Attackers may execute spreadsheet formulas that exfiltrate data, run commands in vulnerable clients, or mislead users opening exported reports.","recommendation":"Prefix formula-like values with a safe escape character, sanitize values beginning with formula operators, and document safe export handling for downstream users.","cve":"","cwe":"CWE-1236","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-71","title":"NoSQL Injection","severity":"High","description":"User-controlled input is used to construct NoSQL queries without safe parameter handling or validation.","risk":"Attackers may bypass authentication, modify query logic, read unauthorized data, or alter database operations.","recommendation":"Use safe query builders, validate expected data types, reject operators in user input where not intended, and apply least-privilege database accounts.","cve":"","cwe":"CWE-943","owasp":"A03:2021 Injection","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-72","title":"GraphQL Introspection Exposed","severity":"Low","description":"GraphQL introspection is enabled in an environment where schema discovery should be restricted.","risk":"Attackers may enumerate types, queries, mutations, and hidden fields to plan targeted attacks.","recommendation":"Disable introspection in production where appropriate, require authentication for schema access, and enforce authorization on all resolvers regardless of schema visibility.","cve":"","cwe":"CWE-200","owasp":"A05:2021 Security Misconfiguration","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-73","title":"GraphQL Authorization Bypass","severity":"High","description":"GraphQL resolvers rely on front-end controls or top-level checks and fail to enforce authorization consistently across nested fields or mutations.","risk":"Attackers may access restricted objects, hidden fields, or privileged mutations by crafting custom GraphQL queries.","recommendation":"Enforce authorization in every resolver and object relationship, apply depth and complexity limits, and add negative tests for nested data access.","cve":"","cwe":"CWE-862","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-74","title":"WebSocket Missing Authentication or Authorization","severity":"High","description":"WebSocket connections or messages are accepted without proper authentication, session validation, or per-message authorization.","risk":"Attackers may subscribe to unauthorized channels, send privileged messages, or receive sensitive real-time data.","recommendation":"Authenticate WebSocket handshakes, validate sessions throughout the connection lifecycle, authorize every message/channel, and close connections on logout or token expiry.","cve":"","cwe":"CWE-306","owasp":"A01:2021 Broken Access Control","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"},
  {"id":"kb-75","title":"OAuth Redirect URI Misconfiguration","severity":"High","description":"OAuth or OIDC flows allow weak, wildcard, or user-controlled redirect URIs.","risk":"Attackers may steal authorization codes or tokens by redirecting users to attacker-controlled domains.","recommendation":"Use exact redirect URI allowlists, avoid wildcards, bind authorization codes to clients with PKCE, and validate state parameters.","cve":"","cwe":"CWE-601","owasp":"A07:2021 Identification and Authentication Failures","createdAt":"2026-07-14T00:00:00Z","updatedAt":"2026-07-14T00:00:00Z"}
